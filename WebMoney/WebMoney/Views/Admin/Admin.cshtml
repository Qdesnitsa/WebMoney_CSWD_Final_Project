@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Admin_PageTitle"].Value;
}

@section Styles {
    <link rel="stylesheet" href="~/css/card.css" asp-append-version="true" />
}

<main class="site-main">
    <section class="admin-section">
        <h1>@SharedLocalizer["Admin_Heading"]</h1>
        <h3 class="card-operations-title">@SharedLocalizer["Admin_Actions"]</h3>
        <ul class="card-operations-list">
            <li><a href="#">@SharedLocalizer["Admin_ShowApplications"]</a></li>
            <li><a href="#">@SharedLocalizer["Admin_ShowStatistics"]</a></li>
            <li><a href="#">@SharedLocalizer["Admin_ServiceFeeDebit"]</a></li>
            <li><a href="#">@SharedLocalizer["Admin_BlockUser"]</a></li>
            <li><a href="#">@SharedLocalizer["Admin_AddNews"]</a></li>
        </ul>
    </section>
</main>
