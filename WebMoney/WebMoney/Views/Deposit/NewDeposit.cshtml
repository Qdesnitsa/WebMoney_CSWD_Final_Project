@model NewDepositViewModel
@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
  ViewData["Title"] = SharedLocalizer["Deposit_PageTitle"].Value;
}

@section Styles {
  <link rel="stylesheet" href="~/css/newcard.css" asp-append-version="true" />
}

<main class="site-main">
  <section class="new-card-section">
    <h2>@SharedLocalizer["Deposit_Heading", Model.CardNumberMasked]</h2>
    <p class="new-card-field-hint">@SharedLocalizer["Deposit_Hint"]</p>

    <div class="new-card-field">
      <span class="new-card-caption">@SharedLocalizer["Deposit_Sender"]</span>
      <input type="text" readonly class="new-card-input-readonly" value="@(SharedLocalizer["Deposit_SenderName"])" />
    </div>

    <form class="new-card-form" asp-controller="Deposit" asp-action="NewDeposit" method="post" novalidate>
      <input type="hidden" asp-for="CardId"/>
      <input type="hidden" asp-for="CardNumberMasked"/>

      <div class="new-card-field">
        <label class="new-card-caption" asp-for="Amount">@SharedLocalizer["Deposit_AmountLabel"]</label>
        <input asp-for="Amount" type="number" min="0.01" step="0.01" inputmode="decimal"/>
        <span asp-validation-for="Amount" class="new-card-hint"></span>
      </div>

      <div class="new-card-actions">
        <button type="submit" class="new-card-submit">@SharedLocalizer["Deposit_Submit"]</button>
        <a asp-controller="Card" asp-action="Card" class="new-card-back">@SharedLocalizer["Card_BackToCards"]</a>
      </div>
    </form>
  </section>
</main>
