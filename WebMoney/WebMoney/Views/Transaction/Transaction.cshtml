@model TransactionViewModel

@{
    ViewData["Title"] = "Транзакции";
}

@section Styles {
  <link rel="stylesheet" href="~/css/transaction.css" asp-append-version="true"/>
}

<main class="site-main">
  <section class="transaction-section">
    <h2 id="transaction-period-heading">Список транзакций по карте @Model.CardNumber</h2>
    <form asp-controller="Transaction" asp-action="Transaction" method="get" class="transaction-form">
      <input type="hidden" asp-for="CardId" />
      <div class="transaction-period-row">
        <div class="transaction-field">
          <label asp-for="PeriodFrom">С даты (включительно)</label>
          <input asp-for="PeriodFrom" type="date" required />
          <span asp-validation-for="PeriodFrom" class="login-hint"></span>
        </div>
        <div class="transaction-field">
          <label asp-for="PeriodTo">По дату (включительно)</label>
          <input asp-for="PeriodTo" type="date" required />
          <span asp-validation-for="PeriodTo" class="login-hint"></span>
        </div>
      </div>
      <button type="submit" class="transaction-submit">Показать транзакции</button>
      <a asp-controller="Card" asp-action="Card" class="cards-back">Назад к картам</a>
    </form>

    @if (Model.Transactions.Count > 0)
    {
      <div class="transaction-grid" role="table">
        <div class="transaction-grid-row transaction-grid-row--head" role="row">
          <span role="columnheader">Дата</span>
          <span role="columnheader">Тип</span>
          <span role="columnheader">Статус</span>
          <span role="columnheader">Валюта</span>
          <span role="columnheader" class="transaction-grid-num">Сумма</span>
          <span role="columnheader">Контрагент</span>
          <span role="columnheader">RRN</span>
        </div>
        @foreach (var txn in Model.Transactions)
        {
          <div class="transaction-grid-row" role="row">
            <span>@txn.DateTime.ToString("dd.MM.yyyy HH:mm")</span>
            <span>@txn.TransactionType</span>
            <span>@txn.TransactionStatus</span>
            <span>@txn.CurrencyCode</span>
            <span class="transaction-grid-num">@txn.Amount.ToString("N2")</span>
            <span>@txn.Counterparty</span>
          </div>
        }
      </div>
    }
    else if (Model.ShowEmptyPeriodMessage)
    {
      <p class="transaction-empty">За выбранный период операций нет.</p>
    }
  </section>
</main>
