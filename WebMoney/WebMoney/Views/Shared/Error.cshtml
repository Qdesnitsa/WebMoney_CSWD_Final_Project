@model ErrorViewModel
@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Error_Title"].Value;
}

@section Styles {
    <link rel="stylesheet" href="~/css/error.css" asp-append-version="true"/>
}

<main class="site-main">
    <h1 class="text-danger">@SharedLocalizer["Error_H1"]</h1>
    <h2 class="text-danger">@SharedLocalizer["Error_H2"]</h2>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>@SharedLocalizer["Error_RequestIdLabel"]</strong> <code>@Model.RequestId</code>
        </p>
    }

    <h3>@SharedLocalizer["Error_DevHeading"]</h3>
    <p>
        @SharedLocalizer["Error_DevP1"]
    </p>
    <p>
        @SharedLocalizer["Error_DevP2"]
    </p>
</main>
