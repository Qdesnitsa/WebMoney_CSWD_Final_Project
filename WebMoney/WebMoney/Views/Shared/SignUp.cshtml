@model SignUpViewModel
@{
    ViewData["Title"] = "Регистрация";
}

@section Styles {
    <link rel="stylesheet" href="~/css/signup.css" asp-append-version="true" />
}

<main class="site-main">
    <section class="login-section">
        <h2 id="login-heading">Зарегистрироваться</h2>
        <form class="login-form" asp-controller="SignUp" asp-action="SignUp" method="post" novalidate>
            <div class="login-field">
                <label asp-for="UserName">Username</label>
                <input asp-for="UserName" autocomplete="username" />
                <span asp-validation-for="UserName" class="login-hint"></span>
            </div>
            <div class="login-field">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" autocomplete="email" />
                <span asp-validation-for="Email" class="login-hint"></span>
            </div>
            <div class="login-field">
                <label asp-for="Password">Пароль</label>
                <input asp-for="Password" autocomplete="new-password" />
                <span asp-validation-for="Password" class="login-hint"></span>
            </div>
            <div class="login-field">
                <label asp-for="ConfirmPassword">Подтвердите пароль</label>
                <input asp-for="ConfirmPassword" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="login-hint"></span>
            </div>
            <div class="login-actions">
                <button type="submit" class="login-submit">Зарегистрироваться</button>
                <a asp-controller="SignIn" asp-action="SignIn" class="login-submit login-submit--outline">Уже есть аккаунт? Войти</a>
            </div>
        </form>
    </section>
</main>
