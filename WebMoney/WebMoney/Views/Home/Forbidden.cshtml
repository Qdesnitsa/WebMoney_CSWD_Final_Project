@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Forbidden_Title"].Value;
}

<main class="site-main">
    <h1>@SharedLocalizer["Forbidden_Heading"]</h1>
    <p>@SharedLocalizer["Forbidden_Body"]</p>
    <p class="site-main-actions">
        <a href="/">@SharedLocalizer["Forbidden_GoHome"]</a>
        <a asp-controller="Auth" asp-action="SignIn">@SharedLocalizer["Forbidden_SignInAsOther"]</a>
    </p>
</main>
