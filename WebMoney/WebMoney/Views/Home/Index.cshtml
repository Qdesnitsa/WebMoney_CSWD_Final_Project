@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Home_PageTitle"].Value;
}

<main class="site-main">
    <article id="about-company" class="about-company">
        <h2>@SharedLocalizer["Home_About_H2"]</h2>
        <p>@SharedLocalizer["Home_About_P1"]</p>
        <p>@SharedLocalizer["Home_About_P2"]</p>
        <p>@SharedLocalizer["Home_About_P3Intro"]</p>
        <ul>
            <li>@SharedLocalizer["Home_About_Li1"]</li>
            <li>@SharedLocalizer["Home_About_Li2"]</li>
            <li>@SharedLocalizer["Home_About_Li3"]</li>
        </ul>
        <p>@SharedLocalizer["Home_About_P4"]</p>
    </article>

    <section id="currency-rates" class="currency-rates">
        <h2 id="currency-rates-heading">@SharedLocalizer["Layout_NavRates"]</h2>
        <p>@SharedLocalizer["Home_Rates_Note"]</p>
        <div class="rates-table">
            <p class="rates-table-caption">@SharedLocalizer["Home_Rates_Caption"]</p>
            <div class="rates-grid rates-grid-head">
                <div class="rates-cell rates-head-cell">@SharedLocalizer["Home_Rates_ColCurrency"]</div>
                <div class="rates-cell rates-head-cell">@SharedLocalizer["Home_Rates_ColBuy"]</div>
                <div class="rates-cell rates-head-cell">@SharedLocalizer["Home_Rates_ColSell"]</div>
            </div>
            <div class="rates-grid">
                <div class="rates-cell">
                    <span class="rates-currency-cell">
                        <img class="rates-currency-icon" src="/images/currency_logos/usd.svg">
                        <span class="rates-currency-code">1 USD</span>
                    </span>
                </div>
                <div class="rates-cell">2.9400</div>
                <div class="rates-cell">2.9780</div>
            </div>
            <div class="rates-grid">
                <div class="rates-cell">
                    <span class="rates-currency-cell">
                        <img class="rates-currency-icon" src="/images/currency_logos/euro.svg">
                        <span class="rates-currency-code">1 EUR</span>
                    </span>
                </div>
                <div class="rates-cell">3.3830</div>
                <div class="rates-cell">3.4280</div>
            </div>
            <div class="rates-grid">
                <div class="rates-cell">
                    <span class="rates-currency-cell">
                        <img class="rates-currency-icon" src="/images/currency_logos/rub.svg">
                        <span class="rates-currency-code">100 RUB</span>
                    </span>
                </div>
                <div class="rates-cell">3.6250</div>
                <div class="rates-cell">3.6750</div>
            </div>
            <div class="rates-grid">
                <div class="rates-cell">
                    <span class="rates-currency-cell">
                        <img class="rates-currency-icon" src="/images/currency_logos/cny.svg">
                        <span class="rates-currency-code">10 CNY</span>
                    </span>
                </div>
                <div class="rates-cell">4.3000</div>
                <div class="rates-cell">4.5500</div>
            </div>
        </div>
    </section>

    <section id="news" class="site-news">
        <h2 id="news-heading">@SharedLocalizer["Layout_NavNews"]</h2>
        <ul class="news-list">
            <li>
                <article class="news-card">
                    <time class="news-date" datetime="2026-03-28">@SharedLocalizer["Home_News1_Time"]</time>
                    <h3 class="news-title">@SharedLocalizer["Home_News1_Title"]</h3>
                    <p class="news-content">@SharedLocalizer["Home_News1_Body"]</p>
                </article>
            </li>
            <li>
                <article class="news-card">
                    <time class="news-date" datetime="2026-03-26">@SharedLocalizer["Home_News2_Time"]</time>
                    <h3 class="news-title">@SharedLocalizer["Home_News2_Title"]</h3>
                    <p class="news-content">@SharedLocalizer["Home_News2_Body"]</p>
                </article>
            </li>
            <li>
                <article class="news-card">
                    <time class="news-date" datetime="2026-03-22">@SharedLocalizer["Home_News3_Time"]</time>
                    <h3 class="news-title">@SharedLocalizer["Home_News3_Title"]</h3>
                    <p class="news-content">@SharedLocalizer["Home_News3_Body"]</p>
                </article>
            </li>
            <li>
                <article class="news-card">
                    <time class="news-date" datetime="2026-03-18">@SharedLocalizer["Home_News4_Time"]</time>
                    <h3 class="news-title">@SharedLocalizer["Home_News4_Title"]</h3>
                    <p class="news-content">@SharedLocalizer["Home_News4_Body"]</p>
                </article>
            </li>
            <li>
                <article class="news-card">
                    <time class="news-date" datetime="2026-03-14">@SharedLocalizer["Home_News5_Time"]</time>
                    <h3 class="news-title">@SharedLocalizer["Home_News5_Title"]</h3>
                    <p class="news-content">@SharedLocalizer["Home_News5_P1"]<br>@SharedLocalizer["Home_News5_P2"]</p>
                </article>
            </li>
        </ul>
    </section>

</main>
