@model CardViewModel

@{
  ViewData["Title"] = "Мой профиль";
}

@section Styles {
  <link rel="stylesheet" href="~/css/card.css" asp-append-version="true" />
}

<main class="site-main">
  <section class="user-cards-section">
    <div class="user-cards-heading-row">
      <h2 id="user-cards-heading">Мои карты</h2>
    </div>
    <div class="user-cards-layout">
      @foreach (var card in Model.Cards)
      {
        <article class="user-card-block">
          <div class="bank-card">
            <div class="bank-card-body">
              <span class="bank-card-number-label">Номер карты</span>
              <span class="bank-card-number-value">@card.Number</span>
              <div class="bank-card-valid">
                <span class="bank-card-valid-label">Действует до</span>
                <span class="bank-card-valid-value">@card.ValidThru</span>
              </div>
            </div>
            <div class="bank-card-footer">
              <span class="bank-card-holder-label">Владелец</span>
              <span class="bank-card-holder">@card.UserEmail</span>
              <span class="bank-card-holder-label">Баланс</span>
              <span class="bank-card-holder">@card.Balance.ToString("N2") @card.CurrencyCode</span>
            </div>
          </div>
          <h3 class="card-operations-title card-operations-title--first">Платежные операции</h3>
          <ul class="card-operations-list">
            <li><a asp-controller="Deposit" asp-action="NewDeposit" asp-route-cardId="@card.Id">Пополнить карту</a></li>
            <li><a href="#">Перевести на другую карту</a></li>
            <li><a href="#">Создать платёж</a></li>
            <li><a asp-controller="Transaction" asp-action="Transaction" asp-route-cardId="@card.Id">Посмотреть историю операций</a></li>
          </ul>
          <h3 class="card-operations-title card-operations-title--next">Управление пользователями</h3>
          <ul class="card-operations-list">
            <li><a asp-controller="Card" asp-action="AddUser" asp-route-cardId="@card.Id">Добавить пользователя</a></li>
            <li><a asp-controller="Card" asp-action="EditUsers" asp-route-id="@card.Id">Редактировать пользователей</a></li>
          </ul>
          <h3 class="card-operations-title card-operations-title--next">Управление картами</h3>
          <ul class="card-operations-list">
            <li><a asp-controller="Card" asp-action="NewCard">Добавить карту</a></li>
            <li><a href="#">Заблокировать карту</a></li>
          </ul>
        </article>
      }

    </div>
  </section>
</main>
