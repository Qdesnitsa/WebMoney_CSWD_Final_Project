@model CardViewModel
@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
  ViewData["Title"] = SharedLocalizer["Card_IndexTitle"].Value;
}

@section Styles {
  <link rel="stylesheet" href="~/css/card.css" asp-append-version="true"/>
}

<main class="site-main">
  <section class="user-cards-section">
    <div class="user-cards-heading-row">
      <h2 id="user-cards-heading">@SharedLocalizer["Card_MyCards"]</h2>
      @if (Model.Cards.Any(c => c.IsOwner))
      {
        <a asp-controller="Card" asp-action="NewCard" class="user-cards-add-card">@SharedLocalizer["Card_AddCard"]</a>
      }
    </div>
    <div class="user-cards-layout">
      @foreach (var card in Model.Cards)
      {
        <article class="user-card-block">
          <div class="bank-card">
            <div class="bank-card-body">
              <span class="bank-card-number-label">@SharedLocalizer["Card_LabelCardNumber"]</span>
              <span class="bank-card-number-value">@card.Number</span>
              <div class="bank-card-valid">
                <span class="bank-card-valid-label">@SharedLocalizer["Card_LabelValidThru"]</span>
                <span class="bank-card-valid-value">@card.ValidThru</span>
              </div>
            </div>
            <div class="bank-card-footer">
              <span class="bank-card-holder-label">@SharedLocalizer["Card_LabelHolder"]</span>
              <span class="bank-card-holder">@card.UserEmail</span>
              <span class="bank-card-holder-label">@SharedLocalizer["Card_LabelBalance"]</span>
              <span class="bank-card-holder">@card.Balance.ToString("N2", CultureInfo.CurrentCulture) @SharedLocalizer["Enum_CurrencyCode_" + card.CurrencyCode]</span>
            </div>
          </div>
          @if (card.ShowPaymentOperations)
          {
            <h3 class="card-operations-title card-operations-title--first">@SharedLocalizer["Card_SectionPayments"]</h3>
            <ul class="card-operations-list">
              <li><a asp-controller="Deposit" asp-action="NewDeposit" asp-route-cardId="@card.Id">@SharedLocalizer["Card_Deposit"]</a>
              </li>
              <li><a href="#">@SharedLocalizer["Card_TransferOther"]</a></li>
              <li><a href="#">@SharedLocalizer["Card_CreatePayment"]</a></li>
              <li><a asp-controller="Transaction" asp-action="Transaction" asp-route-cardId="@card.Id">@SharedLocalizer["Card_ViewHistory"]</a></li>
            </ul>
          }
          @if (card.ShowUserManagement)
          {
            <h3 class="card-operations-title card-operations-title--next">@SharedLocalizer["Card_SectionUserMgmt"]</h3>
            <ul class="card-operations-list">
              <li><a asp-controller="Card" asp-action="AddUser" asp-route-cardId="@card.Id">@SharedLocalizer["Card_AddUserLink"]</a>
              </li>
              <li><a asp-controller="Card" asp-action="EditUsers" asp-route-cardId="@card.Id">@SharedLocalizer["Card_EditUsersLink"]</a></li>
            </ul>
          }
          @if (card.IsOwner)
          {
            <h3 class="card-operations-title card-operations-title--next">@SharedLocalizer["Card_SectionCard"]</h3>
            <ul class="card-operations-list">
              <li><a href="#">@SharedLocalizer["Card_BlockCard"]</a></li>
            </ul>
          }
        </article>
      }

    </div>
  </section>
</main>
