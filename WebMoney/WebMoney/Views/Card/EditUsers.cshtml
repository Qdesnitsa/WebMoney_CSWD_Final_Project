@model EditUsersViewModel
@using System.Globalization
@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
  ViewData["Title"] = SharedLocalizer["Card_EditUsersPageTitle", Model.CardNumberMasked].Value;
}

@section Styles {
  <link rel="stylesheet" href="~/css/newcard.css" asp-append-version="true"/>
  <link rel="stylesheet" href="~/css/edit-card-users.css" asp-append-version="true"/>
}

<main class="site-main">
  <section class="new-card-section edit-card-users-wrap">
    <h2>@SharedLocalizer["Card_EditUsersHeading", Model.CardNumberMasked]</h2>
    @if (Model.Users.Count == 0)
    {
      <p class="new-card-field-hint">@SharedLocalizer["Card_EditUsersEmpty1"]<br>@SharedLocalizer["Card_EditUsersEmpty2"]</p>
    }
    else
    {
      @foreach (var user in Model.Users)
      {
        <article class="edit-card-user-row">
          <form asp-controller="Card" asp-action="EditUsers" asp-route-id="@Model.CardId" method="post"
                class="edit-card-user-settings-form" novalidate>
            <input type="hidden" name="CardId" value="@Model.CardId"/>
            <input type="hidden" name="CardUserProfileId" value="@user.CardUserProfileId"/>

            <div class="edit-card-user-main-row">
              <div class="edit-card-user-email-col">
                <p class="edit-card-user-email">
                  @user.UserEmail
                  @if (user.IsOwner)
                  {
                    <span>@SharedLocalizer["Card_OwnerBadge"]</span>
                  }
                </p>
              </div>
              <div class="edit-card-user-limits-row">
                @if (Model.CurrentUserMayManageUsers && !user.IsOwner)
                {
                  <fieldset class="edit-card-user-rights">
                    <legend>@SharedLocalizer["Card_FieldsetExtraRights"]</legend>
                    <p class="new-card-field-hint">@SharedLocalizer["Card_EditUsersRightsHint"]</p>
                    <div class="new-card-field new-card-field-inline">
                      <input type="hidden" name="CanManageUsers" value="false"/>
                      <input id="cup_@(user.CardUserProfileId)_mu" type="checkbox" name="CanManageUsers" value="true"
                             class="new-card-field-inline-check" @(user.CanManageUsers ? "checked=\"checked\"" : null)/>
                      <div>
                        <label for="cup_@(user.CardUserProfileId)_mu">@SharedLocalizer["Card_CanManageUsersLabel"]</label>
                      </div>
                    </div>
                  </fieldset>
                }
                <div class="edit-card-user-fields-horizontal">
                  <div class="new-card-field edit-card-user-limit-field">
                    <label class="new-card-caption" for="DailyLimit_@user.CardUserProfileId">@SharedLocalizer["Card_LimitDaily"]</label>
                    <input id="DailyLimit_@user.CardUserProfileId"
                           name="DailyLimit"
                           class="new-card-limit"
                           type="number"
                           min="0"
                           step="0.01"
                           inputmode="decimal"
                           value="@(user.DailyLimit?.ToString(CultureInfo.InvariantCulture))"/>
                  </div>
                  <div class="new-card-field edit-card-user-limit-field">
                    <label class="new-card-caption" for="MonthlyLimit_@user.CardUserProfileId">@SharedLocalizer["Card_LimitMonthly"]</label>
                    <input id="MonthlyLimit_@user.CardUserProfileId"
                           name="MonthlyLimit"
                           class="new-card-limit"
                           type="number"
                           min="0"
                           step="0.01"
                           inputmode="decimal"
                           value="@(user.MonthlyLimit?.ToString(CultureInfo.InvariantCulture))"/>
                  </div>
                  <div class="new-card-field edit-card-user-limit-field">
                    <label class="new-card-caption" for="PerOperationLimit_@user.CardUserProfileId">@SharedLocalizer["Card_LimitPerOperation"]</label>
                    <input id="PerOperationLimit_@user.CardUserProfileId"
                           name="PerOperationLimit"
                           class="new-card-limit"
                           type="number"
                           min="0"
                           step="0.01"
                           inputmode="decimal"
                           value="@(user.PerOperationLimit?.ToString(CultureInfo.InvariantCulture))"/>
                  </div>
                </div>
                <div class="edit-card-user-actions new-card-actions">
                  <button type="submit" class="new-card-submit">@SharedLocalizer["Card_SaveSettings"]</button>
                </div>
              </div>
            </div>
          </form>

          @if (!user.IsOwner)
          {
            <form asp-controller="Card" asp-action="RemoveUser" asp-route-id="@Model.CardId" method="post"
                  class="new-card-actions">
              <input type="hidden" name="CardId" value="@Model.CardId"/>
              <input type="hidden" name="CardUserProfileId" value="@user.CardUserProfileId"/>
              <button type="submit" class="new-card-back">@SharedLocalizer["Card_Unlink"]</button>
            </form>
          }
        </article>
      }
    }

    <div class="new-card-actions">
      <a asp-controller="Card" asp-action="AddUser" asp-route-cardId="@Model.CardId" class="new-card-submit">@SharedLocalizer["Card_AddUserPrimary"]</a>
      <a asp-controller="Card" asp-action="Card" class="new-card-back">@SharedLocalizer["Card_BackToCards"]</a>
    </div>
  </section>
</main>
